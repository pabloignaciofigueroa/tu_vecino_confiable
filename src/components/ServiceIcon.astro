---
// Ícono de servicio dentro de círculo de color por categoría (guía §6).
// soft=true → círculo pastel + glifo intenso; soft=false → círculo intenso + glifo blanco.
// `color`/`softBg` permiten usarlo fuera de las categorías (ej: métricas admin).
interface Props {
  icon: string;
  cat?: string;
  size?: number;
  soft?: boolean;
  color?: string;
  softBg?: string;
}
const { icon, cat = '', size = 44, soft = false, color, softBg } = Astro.props;
const fuerte = color ?? `var(--cat-${cat})`;
const pastel = softBg ?? `var(--cat-${cat}-soft)`;
---

<span
  class:list={['sicon', { 'sicon--soft': soft }]}
  style={`--cat: ${fuerte}; --cat-soft: ${pastel}; --size: ${size}px;`}
  aria-hidden="true"
>
  {icon === 'avion' && (
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M21.5 15.5v-2.2l-8.3-5.2V3.6a1.6 1.6 0 0 0-3.2 0v4.5l-8.3 5.2v2.2l8.3-2.6v5l-2.2 1.6v1.7l3.8-1.1 3.8 1.1v-1.7l-2.2-1.6v-5l8.3 2.6z" />
    </svg>
  )}
  {icon === 'ruta' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 21s-6.5-6.6-6.5-11A6.5 6.5 0 0 1 12 3.5 6.5 6.5 0 0 1 18.5 10c0 4.4-6.5 11-6.5 11z" />
      <circle cx="12" cy="10" r="2.4" />
    </svg>
  )}
  {icon === 'copas' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m5 3 7 8 7-8H5z" />
      <path d="M12 11v8" />
      <path d="M8 21h8" />
      <path d="M7.5 5.8h9" />
    </svg>
  )}
  {icon === 'sillon' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5.5 11V7a3 3 0 0 1 3-3h7a3 3 0 0 1 3 3v4" />
      <path d="M3 13a2 2 0 0 1 4 0v1h10v-1a2 2 0 0 1 4 0v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4z" />
      <path d="M6.5 20v1.5" />
      <path d="M17.5 20v1.5" />
    </svg>
  )}
  {icon === 'camion' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 6h11v10H3z" />
      <path d="M14 9h4l3 3v4h-7" />
      <circle cx="7" cy="18" r="1.8" />
      <circle cx="17" cy="18" r="1.8" />
    </svg>
  )}
  {icon === 'clipboard' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
      <rect x="9" y="2.5" width="6" height="3.5" rx="1.2" />
      <path d="M9 12h6" />
      <path d="M9 16h4" />
    </svg>
  )}
  {icon === 'herramientas' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
    </svg>
  )}
  {icon === 'ventana' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="4" y="4" width="16" height="16" rx="2" />
      <path d="M12 4v16" />
      <path d="M4 12h16" />
    </svg>
  )}
  {icon === 'rodillo' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="14" height="6" rx="2" />
      <path d="M17 5h2a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-7a2 2 0 0 0-2 2v1" />
      <rect x="9" y="15" width="3" height="6" rx="1.2" />
    </svg>
  )}
  {icon === 'check' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
      <path d="m4.5 12.5 5 5 10-11" />
    </svg>
  )}
  {icon === 'moneda' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="9" />
      <path d="M14.8 8.8A3.2 3.2 0 0 0 12 7.5c-1.8 0-3.2 1-3.2 2.3s1.1 1.9 3.2 2.2c2.3.3 3.4 1 3.4 2.4S13.9 16.7 12 16.7a3.4 3.4 0 0 1-3-1.4" />
      <path d="M12 5.5v2" />
      <path d="M12 16.7v1.8" />
    </svg>
  )}
  {icon === 'estrella' && (
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="m12 2.5 2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17.4l-5.9 3.1 1.2-6.5L2.5 9.4l6.6-.9 2.9-6z" />
    </svg>
  )}
</span>

<style>
  .sicon {
    width: var(--size);
    height: var(--size);
    min-width: var(--size);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--cat);
    color: #fff;
  }

  .sicon--soft {
    background: var(--cat-soft);
    color: var(--cat);
  }

  .sicon :global(svg) {
    width: 55%;
    height: 55%;
  }
</style>
