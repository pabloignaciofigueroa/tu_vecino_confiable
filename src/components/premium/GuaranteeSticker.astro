---
// Sticker morado irregular "Servicio garantizado" (no círculo perfecto).
// Forma en SVG + escudo + rayitas decorativas + flotación sutil.
interface Props {
  class?: string;
  animated?: boolean;
}
const { class: className = '', animated = true } = Astro.props;
---

<div
  class:list={['guarantee', { 'tv-motion-sticker-float': animated }, className]}
  role="img"
  aria-label="Servicio garantizado"
>
  <svg class="guarantee__shape" viewBox="0 0 180 156" aria-hidden="true">
    <path
      d="M26,36 C42,9 78,16 98,11 C130,3 160,21 164,53 C186,73 170,118 140,128 C114,152 73,144 53,134 C21,134 5,101 17,79 C1,57 11,43 26,36Z"
    ></path>
  </svg>

  <span class="guarantee__rays" aria-hidden="true">
    <i></i><i></i><i></i><i></i>
  </span>

  <span class="guarantee__content" aria-hidden="true">
    <svg class="guarantee__shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2.5 4.5 5.5v6c0 4.6 3.2 8 7.5 9.5 4.3-1.5 7.5-4.9 7.5-9.5v-6L12 2.5z" />
      <path d="m8.8 12 2.2 2.2 4.2-4.4" />
    </svg>
    <strong>Servicio</strong>
    <strong>garantizado</strong>
  </span>
</div>

<style>
  .guarantee {
    position: relative;
    width: 124px;
    height: 108px;
    display: grid;
    place-items: center;
    color: #fff;
    transform: rotate(-5deg);
    filter: drop-shadow(0 12px 22px rgba(4, 17, 38, 0.24));
  }

  .guarantee__shape {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .guarantee__shape path {
    fill: var(--tv-purple-500);
    stroke: rgba(255, 255, 255, 0.35);
    stroke-width: 2;
  }

  .guarantee__content {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    text-align: center;
    text-transform: uppercase;
    font-size: 0.72rem;
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: 0.04em;
  }

  .guarantee__shield {
    width: 22px;
    height: 22px;
    margin-bottom: 2px;
  }

  /* rayitas tipo destello alrededor del sello */
  .guarantee__rays i {
    position: absolute;
    width: 3px;
    height: 9px;
    border-radius: 2px;
    background: var(--tv-yellow-400);
  }
  .guarantee__rays i:nth-child(1) { top: -4px; left: 30%; transform: rotate(-18deg); }
  .guarantee__rays i:nth-child(2) { top: 8px; right: -2px; transform: rotate(40deg); }
  .guarantee__rays i:nth-child(3) { bottom: 4px; left: -3px; transform: rotate(-46deg); }
  .guarantee__rays i:nth-child(4) { bottom: -3px; right: 26%; transform: rotate(16deg); }
</style>
