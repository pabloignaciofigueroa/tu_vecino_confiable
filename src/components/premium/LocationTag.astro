---
// Etiqueta de ubicación con pin, en color de categoría.
interface Props {
  color?: string;
  class?: string;
}
const { color = 'var(--tv-coral-500)', class: className = '' } = Astro.props;
---

<span class={`location-tag ${className}`} style={`--loc:${color}`}>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 21s-6.5-6.6-6.5-11A6.5 6.5 0 0 1 12 3.5 6.5 6.5 0 0 1 18.5 10c0 4.4-6.5 11-6.5 11z" />
    <circle cx="12" cy="10" r="2.4" />
  </svg>
  <slot />
</span>

<style>
  .location-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    color: var(--loc);
    font-size: 0.66rem;
    font-weight: 900;
  }

  .location-tag svg { width: 12px; height: 12px; }
</style>
