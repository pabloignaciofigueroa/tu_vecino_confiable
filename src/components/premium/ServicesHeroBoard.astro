---
import JorgeTrustCard from './JorgeTrustCard.astro';
import BrushHighlight from './BrushHighlight.astro';
import DoodleLayer from './DoodleLayer.astro';

// Cabecera editorial de Servicios: lettering "Servicios" + subrayado coral +
// highlight amarillo + card premium de Jorge + doodles.
interface Props {
  jorgePhoto: ImageMetadata;
}
const { jorgePhoto } = Astro.props;
---

<section class="services-hero tv-texture-paper">
  <DoodleLayer class="services-hero__doodles" color="var(--tv-coral-400)" size={82} />

  <div class="services-hero__row">
    <div class="services-hero__heading">
      <h1 class="tv-display services-hero__title">Servicios</h1>
      <span class="tv-underline-coral"></span>
      <BrushHighlight class="services-hero__brush" rotate="-1.5deg">
        Lo que necesitas,<br />resuelto con<br />confianza y<br />buena onda
      </BrushHighlight>
    </div>
    <JorgeTrustCard class="services-hero__jorge" photo={jorgePhoto} />
  </div>
</section>

<style>
  .services-hero {
    position: relative;
    overflow: hidden;
    padding: 0.7rem var(--page-x) 0.75rem;
    background: var(--tv-cream-50);
    border-radius: 0 0 24px 24px;
  }

  .services-hero__doodles {
    position: absolute;
    top: 4px;
    left: 6px;
    opacity: 0.7;
    z-index: 0;
  }

  /* dos columnas equilibradas: pila de texto a la izq, card de Jorge a la der */
  .services-hero__row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 1fr);
    gap: 0.6rem;
    align-items: center;
  }

  .services-hero__heading {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.32rem;
  }

  .services-hero__title {
    font-size: clamp(2.1rem, 10.5vw, 2.9rem);
  }

  /* achicado y en líneas cortas para caber en la columna izquierda */
  .services-hero__brush {
    margin-top: 0.15rem;
    font-size: 0.78rem;
  }
</style>
