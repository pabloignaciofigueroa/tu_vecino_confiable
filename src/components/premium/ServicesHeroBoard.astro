---
import JorgeTrustCard from './JorgeTrustCard.astro';
import BrushHighlight from './BrushHighlight.astro';

// Cabecera editorial de Servicios: lettering "Servicios" + subrayado coral +
// highlight amarillo + card premium de Jorge. Los doodles son acentos sueltos
// anclados a cada elemento (no un cluster de relleno en la esquina).
interface Props {
  jorgePhoto: ImageMetadata;
}
const { jorgePhoto } = Astro.props;
---

<section class="services-hero tv-texture-paper">
  <div class="services-hero__row">
    <div class="services-hero__heading">
      <!-- chispa pegada a la esquina superior del título -->
      <span class="dood dood--spark" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M12 2C12.8 8 16 11.2 22 12 16 12.8 12.8 16 12 22 11.2 16 8 12.8 2 12 8 11.2 11.2 8 12 2Z" fill="currentColor" />
        </svg>
      </span>

      <h1 class="tv-display services-hero__title">Servicios</h1>
      <span class="tv-underline-coral"></span>
      <BrushHighlight class="services-hero__brush" rotate="-1.5deg">
        Lo que necesitas,<br />resuelto con<br />confianza y<br />buena onda
      </BrushHighlight>

      <!-- corazón cálido junto al brush -->
      <span class="dood dood--heart" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M12 20s-7-4.6-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.4-7 10-7 10Z" fill="currentColor" />
        </svg>
      </span>
    </div>

    <JorgeTrustCard class="services-hero__jorge" photo={jorgePhoto} />
  </div>
</section>

<style>
  .services-hero {
    position: relative;
    overflow: hidden;
    padding: 0.5rem var(--page-x) 0.7rem;
    background: var(--tv-cream-50);
    border-radius: 0 0 24px 24px;
  }

  /* dos columnas equilibradas: pila de texto a la izq, card de Jorge a la der */
  .services-hero__row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 1fr);
    gap: 0.6rem;
    align-items: center;
  }

  .services-hero__heading {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.32rem;
  }

  .services-hero__title {
    font-size: clamp(2.1rem, 10.5vw, 2.9rem);
  }

  /* achicado y en líneas cortas para caber en la columna izquierda */
  .services-hero__brush {
    margin-top: 0.15rem;
    font-size: 0.78rem;
  }

  /* ---- doodles como acentos anclados (no relleno) ---- */
  .dood {
    position: absolute;
    z-index: 0;
    pointer-events: none;
    display: block;
  }

  .dood svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* chispa pegada a la esquina superior-derecha del título */
  .dood--spark {
    top: -10px;
    right: -14px;
    width: 22px;
    height: 22px;
    color: var(--tv-coral-400);
    transform: rotate(8deg);
  }

  /* corazón cálido al costado del brush */
  .dood--heart {
    bottom: 4px;
    right: 2px;
    width: 18px;
    height: 18px;
    color: var(--tv-pink-500);
    transform: rotate(-10deg);
  }
</style>
