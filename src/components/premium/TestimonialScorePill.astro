---
// Pill compacto de prueba social: medalla + 5.0 + "Más de 200 vecinos satisfechos".
interface Props {
  score?: string;
  caption?: string;
  class?: string;
}
const {
  score = '5.0',
  caption = 'Más de 200 vecinos satisfechos',
  class: className = '',
} = Astro.props;
---

<div class={`score-pill ${className}`}>
  <span class="score-pill__medal" aria-hidden="true">★</span>
  <div class="score-pill__copy">
    <strong>{score} <span aria-hidden="true">★★★★★</span></strong>
    <span>{caption}</span>
  </div>
</div>

<style>
  .score-pill {
    display: inline-grid;
    grid-template-columns: 40px 1fr;
    gap: 0.6rem;
    align-items: center;
    padding: 0.5rem 0.85rem 0.5rem 0.55rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: var(--tv-shadow-card);
  }

  .score-pill__medal {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--tv-yellow-400);
    color: var(--tv-ink);
    font-size: 1.1rem;
    font-weight: 900;
    box-shadow: inset 0 -5px 10px rgba(229, 169, 0, 0.4);
  }

  .score-pill__copy strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    color: var(--tv-ink);
  }

  .score-pill__copy strong span {
    color: var(--tv-yellow-500);
    font-size: 0.72rem;
    letter-spacing: 1px;
  }

  .score-pill__copy > span {
    display: block;
    margin-top: 0.1rem;
    font-size: 0.68rem;
    font-weight: 800;
    color: var(--tv-ink-soft);
  }
</style>
