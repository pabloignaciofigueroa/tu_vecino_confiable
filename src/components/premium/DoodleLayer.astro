---
// Capa de doodles editoriales (estrellas, rayitas, corazón). Decorativa y sutil.
// Se posiciona desde el contenedor padre vía la clase pasada.
interface Props {
  class?: string;
  color?: string;
  size?: number;
}
const { class: className = '', color = 'var(--tv-coral-400)', size } = Astro.props;
// tamaño inline (gana a cualquier clase del padre, evita que se estire a ancho completo).
const style = size ? `--doodle:${color}; width:${size}px; height:${size}px` : `--doodle:${color}`;
---

<svg
  class={`doodles ${className}`}
  style={style}
  viewBox="0 0 120 120"
  fill="none"
  aria-hidden="true"
>
  <!-- estrella de 4 puntas -->
  <path d="M20 14 C22 22 24 24 32 26 C24 28 22 30 20 38 C18 30 16 28 8 26 C16 24 18 22 20 14Z" fill="var(--doodle)" opacity="0.85" />
  <!-- rayitas -->
  <path d="M96 18 l8 -6 M104 26 l9 -3 M98 34 l8 1" stroke="var(--doodle)" stroke-width="2.4" stroke-linecap="round" opacity="0.7" />
  <!-- corazón pequeño -->
  <path d="M58 96 c-6 -6 -14 -2 -14 5 c0 6 8 11 14 15 c6 -4 14 -9 14 -15 c0 -7 -8 -11 -14 -5Z" fill="var(--doodle)" opacity="0.55" />
  <!-- squiggle -->
  <path d="M86 92 q6 -8 12 0 q6 8 12 0" stroke="var(--doodle)" stroke-width="2.4" stroke-linecap="round" opacity="0.6" />
</svg>

<style>
  .doodles {
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
  }
</style>
