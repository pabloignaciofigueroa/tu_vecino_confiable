---
// Card blanca premium de cobertura (Inicio): icono circular + copy + flecha.
// Doodle lineal muy tenue de fondo para dar textura editorial.
interface Props {
  icon: 'pin' | 'beach';
  title: string;
  text: string;
  href: string;
  iconBg?: string;
  iconFg?: string;
  arrowBg?: string;
  arrowFg?: string;
}
const {
  icon,
  title,
  text,
  href,
  iconBg = 'var(--tv-pink-50)',
  iconFg = 'var(--tv-coral-500)',
  arrowBg = 'var(--tv-blue-50)',
  arrowFg = 'var(--tv-blue-500)',
} = Astro.props;
---

<a
  class="feature-card tv-texture-grain"
  href={href}
  style={`--ic-bg:${iconBg}; --ic-fg:${iconFg}; --ar-bg:${arrowBg}; --ar-fg:${arrowFg};`}
>
  <span class="feature-card__icon" aria-hidden="true">
    {icon === 'pin' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 21s-6.5-6.6-6.5-11A6.5 6.5 0 0 1 12 3.5 6.5 6.5 0 0 1 18.5 10c0 4.4-6.5 11-6.5 11z" />
        <circle cx="12" cy="10" r="2.4" />
      </svg>
    )}
    {icon === 'beach' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 18c2-2 4-2 6 0s4 2 6 0 4-2 6 0" />
        <path d="M3 13c2-2 4-2 6 0s4 2 6 0 4-2 6 0" />
        <circle cx="17.5" cy="6.5" r="2.5" />
      </svg>
    )}
  </span>
  <span class="feature-card__copy">
    <strong>{title}</strong>
    <span>{text}</span>
  </span>
  <span class="feature-card__arrow" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="m9 5 7 7-7 7" />
    </svg>
  </span>
</a>

<style>
  .feature-card {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.5rem;
    min-height: 56px;
    padding: 0.5rem 0.55rem;
    border-radius: 16px;
    background: #fff;
    box-shadow: var(--tv-shadow-card);
    overflow: hidden;
    transition: transform var(--tv-dur-fast) var(--tv-ease-pop);
  }

  .feature-card:active { transform: scale(0.99); }
  .feature-card:focus-visible {
    outline: 3px solid var(--tv-yellow-400);
    outline-offset: 2px;
  }

  .feature-card__icon {
    width: 36px;
    height: 36px;
    flex: none;
    border-radius: 38% 62% 55% 45% / 52% 44% 56% 48%;
    display: grid;
    place-items: center;
    background: var(--ic-bg);
    color: var(--ic-fg);
  }

  .feature-card__icon svg { width: 19px; height: 19px; }

  .feature-card__copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .feature-card__copy strong {
    font-family: var(--font-display);
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.04;
    color: var(--tv-ink);
    overflow-wrap: anywhere;
  }

  .feature-card__copy span {
    font-size: 0.7rem;
    font-weight: 600;
    line-height: 1.12;
    color: var(--tv-ink-soft);
    overflow-wrap: anywhere;
  }

  .feature-card__arrow {
    width: 26px;
    height: 26px;
    flex: none;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--ar-bg);
    color: var(--ar-fg);
  }

  .feature-card__arrow svg { width: 13px; height: 13px; }
</style>
