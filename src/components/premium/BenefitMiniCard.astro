---
// Mini-módulo de beneficio: burbuja de icono + título + microcopy.
// card=false → módulo suelto sobre el panel (Inicio).
// card=true  → tarjeta blanca redondeada (Opiniones, 5 beneficios).
import ServiceIcon from '../ServiceIcon.astro';
interface Props {
  icon: string;
  title: string;
  text: string;
  color?: string;
  soft?: string;
  card?: boolean;
  iconSize?: number;
  class?: string;
}
const {
  icon,
  title,
  text,
  color = 'var(--tv-coral-500)',
  soft = 'var(--tv-pink-50)',
  card = false,
  iconSize = 42,
  class: className = '',
} = Astro.props;
---

<div class:list={['benefit', { 'benefit--card': card }, className]}>
  <ServiceIcon icon={icon} size={iconSize} color={color} softBg={soft} soft blob />
  <strong class="benefit__title">{title}</strong>
  <span class="benefit__text">{text}</span>
</div>

<style>
  .benefit {
    display: grid;
    gap: 0.3rem;
    align-content: start;
    color: var(--tv-ink);
  }

  .benefit--card {
    min-height: 112px;
    padding: 0.7rem 0.6rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: var(--tv-shadow-card);
    transition: transform var(--tv-dur-fast) var(--tv-ease-pop), box-shadow var(--tv-dur-fast) ease;
  }

  .benefit--card:active {
    transform: translateY(2px) scale(0.985);
  }

  .benefit__title {
    margin-top: 0.1rem;
    font-family: var(--font-display);
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.04;
    overflow-wrap: anywhere;
  }

  .benefit__text {
    font-size: 0.68rem;
    font-weight: 600;
    line-height: 1.18;
    color: var(--tv-ink-soft);
    overflow-wrap: anywhere;
  }
</style>
