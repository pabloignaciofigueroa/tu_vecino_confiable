---
import { buildWhatsAppUrl } from '../scripts/whatsapp.js';

// CTA fijo: SIEMPRE el mismo texto para crear memoria visual (guía §4).
// En /servicios el script de la página actualiza el href con el mensaje armado.
const waUrl = buildWhatsAppUrl();
---

<a class="cta-wa tv-texture-grain" id="cta-wa" href={waUrl} target="_blank" rel="noopener">
  <span class="cta-wa-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z">
      </path>
    </svg>
  </span>
  <span class="cta-wa-text">
    <strong>Cotizar por WhatsApp</strong>
    <small>Respuesta rápida y sin compromiso</small>
  </span>
  <span class="cta-wa-hand" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M9 11V5.5a1.5 1.5 0 0 1 3 0V11m0-1.5a1.5 1.5 0 0 1 3 0V12m0-1a1.5 1.5 0 0 1 3 0v4.2c0 3-2.2 5.3-5.3 5.3-1.8 0-3-.6-4.1-1.9l-3-3.6a1.5 1.5 0 0 1 2.2-2L9 14.5V9.5a1.5 1.5 0 0 1 3 0" />
    </svg>
  </span>
</a>

<style>
  .cta-wa {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    margin: 8px var(--page-x);
    min-height: var(--cta-h);
    padding: 9px 16px;
    background:
      radial-gradient(120% 90% at 18% 16%, rgba(255, 255, 255, 0.42), transparent 30%),
      linear-gradient(180deg, #ffd23e 0%, var(--yellow) 55%, var(--yellow-2) 100%);
    border-radius: 22px;
    box-shadow:
      0 14px 28px rgba(255, 196, 0, 0.34),
      0 14px 34px rgba(6, 22, 47, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.55);
    color: var(--navy);
    transition: transform 0.16s var(--tv-ease-pop), filter 0.15s ease, box-shadow 0.16s ease;
  }

  .cta-wa:active {
    transform: translateY(2px) scale(0.985);
    filter: brightness(1.04);
  }

  .cta-wa:focus-visible {
    outline: 3px solid var(--navy);
    outline-offset: 3px;
  }

  /* disco verde WhatsApp */
  .cta-wa-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: #25d366;
    color: #fff;
    box-shadow: inset 0 -5px 12px rgba(0, 0, 0, 0.18), 0 6px 14px rgba(37, 211, 102, 0.4);
  }

  .cta-wa-icon svg {
    width: 28px;
    height: 28px;
    display: block;
  }

  .cta-wa:hover .cta-wa-icon,
  .cta-wa:active .cta-wa-icon {
    animation: wa-pulse 0.7s ease-in-out;
  }

  .cta-wa-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.1;
  }

  .cta-wa-text strong {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .cta-wa-text small {
    margin-top: 2px;
    font-size: 0.74rem;
    font-weight: 800;
    opacity: 0.78;
  }

  .cta-wa-hand {
    width: 30px;
    color: var(--navy);
    opacity: 0.85;
  }

  .cta-wa-hand svg { width: 30px; height: 30px; display: block; }

  @media (prefers-reduced-motion: no-preference) {
    .cta-wa-hand { animation: tv-arrow-nudge 2.4s ease-in-out infinite; }
  }
</style>
