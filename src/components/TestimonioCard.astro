---
// Testimonio: comillas grandes, estrellas amarillas, avatar con iniciales
// y comuna (guía §10 y §13). Cálido, no corporativo.
interface Props {
  texto: string;
  nombre: string;
  comuna: string;
  estrellas: number;
  acento?: string;
}
const { texto, nombre, comuna, estrellas, acento = 'var(--purple)' } = Astro.props;
const iniciales = nombre
  .split(' ')
  .map((p) => p[0])
  .join('')
  .replace('.', '')
  .slice(0, 2)
  .toUpperCase();
---

<figure class="testi" style={`--acento: ${acento};`}>
  <span class="testi-comillas" aria-hidden="true">“</span>
  <div class="testi-stars" role="img" aria-label={`${estrellas} de 5 estrellas`}>
    {Array.from({ length: estrellas }).map(() => <span aria-hidden="true">★</span>)}
  </div>
  <blockquote class="testi-texto">{texto}</blockquote>
  <figcaption class="testi-autor">
    <span class="testi-avatar" aria-hidden="true">{iniciales}</span>
    <span class="testi-meta">
      <strong>{nombre}</strong>
      <small>{comuna}</small>
    </span>
  </figcaption>
</figure>

<style>
  .testi {
    position: relative;
    margin: 0;
    background: #fff;
    border-radius: var(--radius-lg);
    padding: 16px 16px 14px;
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(6, 22, 47, 0.05);
  }

  .testi-comillas {
    position: absolute;
    top: 2px;
    right: 14px;
    font-size: 56px;
    font-weight: 900;
    line-height: 1;
    color: var(--acento);
    opacity: 0.3;
    font-family: Georgia, serif;
  }

  .testi-stars {
    color: var(--yellow);
    font-size: 15px;
    letter-spacing: 2px;
    margin-bottom: 6px;
  }

  .testi-texto {
    margin: 0 0 12px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.45;
  }

  .testi-autor {
    display: flex;
    align-items: center;
    gap: 9px;
  }

  .testi-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--acento);
    color: #fff;
    font-size: 12.5px;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .testi-meta {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .testi-meta strong {
    font-size: 13.5px;
    font-weight: 800;
    color: var(--ink);
  }

  .testi-meta small {
    font-size: 11.5px;
    font-weight: 600;
    color: var(--ink-soft);
  }
</style>
