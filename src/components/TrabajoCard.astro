---
import { Image } from 'astro:assets';
import ServiceIcon from './ServiceIcon.astro';

// Card de trabajo realizado: acento por categoría, foto (antes/después si
// corresponde) y ubicación (guía §10 y §13). La imagen llega por props.
interface Props {
  titulo: string;
  texto: string;
  comuna: string;
  cat: string;
  icono: string;
  foto: ImageMetadata;
  fotoAlt: string;
}
const { titulo, texto, comuna, cat, icono, foto, fotoAlt } = Astro.props;
---

<article class="tcard" style={`--cat: var(--cat-${cat}); --cat-soft: var(--cat-${cat}-soft);`}>
  <header class="tcard-head">
    <ServiceIcon icon={icono} cat={cat} size={34} />
    <h3 class="tcard-titulo">{titulo}</h3>
  </header>
  <Image class="tcard-foto" src={foto} alt={fotoAlt} width={840} densities={[1, 2]} />
  <p class="tcard-texto">{texto}</p>
  <footer class="tcard-lugar">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 21s-6.5-6.6-6.5-11A6.5 6.5 0 0 1 12 3.5 6.5 6.5 0 0 1 18.5 10c0 4.4-6.5 11-6.5 11z" />
      <circle cx="12" cy="10" r="2.4" />
    </svg>
    <span>{comuna}</span>
  </footer>
</article>

<style>
  .tcard {
    background: #fff;
    border-radius: var(--radius-lg);
    padding: 14px;
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(6, 22, 47, 0.05);
    border-top: 5px solid var(--cat);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .tcard-head {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tcard-titulo {
    font-size: 15.5px;
    font-weight: 900;
    color: var(--ink);
  }

  .tcard :global(.tcard-foto) {
    width: 100%;
    height: auto;
    border-radius: 14px;
  }

  .tcard-texto {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-soft);
    line-height: 1.4;
  }

  .tcard-lugar {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12.5px;
    font-weight: 800;
    color: var(--cat);
  }

  .tcard-lugar svg {
    width: 15px;
    height: 15px;
  }
</style>
