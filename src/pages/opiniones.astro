---
import AppShell from '../layouts/AppShell.astro';
import OpinionsHeroPoster from '../components/premium/OpinionsHeroPoster.astro';
import BenefitMiniCard from '../components/premium/BenefitMiniCard.astro';
import WorkCaseCard from '../components/premium/WorkCaseCard.astro';
import TestimonialCardPremium from '../components/premium/TestimonialCardPremium.astro';
import TestimonialScorePill from '../components/premium/TestimonialScorePill.astro';
import HandDrawnArrow from '../components/premium/HandDrawnArrow.astro';
import trabajos from '../data/trabajos.json';
import testimonios from '../data/testimonios.json';
import heroJorge from '../assets/img/hero-camioneta.png';
import fotoCachureos from '../assets/img/trabajo-cachureos.png';
import fotoRepisas from '../assets/img/trabajo-repisas.png';
import fotoFlete from '../assets/img/trabajo-flete.png';

// Datos + imágenes; las cards reciben props.
const fotos: Record<string, { src: ImageMetadata; alt: string }> = {
  cachureos: { src: fotoCachureos, alt: 'Antes y después de un retiro de cachureos en un patio' },
  repisas: { src: fotoRepisas, alt: 'Antes y después de repisas a medida instaladas en bodega' },
  flete: { src: fotoFlete, alt: 'Camioneta roja cargada con cajas para un flete pequeño' },
};

// 5 beneficios (mapeados a glifos disponibles + color/soft de marca).
const confianza = [
  { titulo: 'Atención directa', texto: 'Hablo contigo desde el inicio', icono: 'chat', color: 'var(--tv-coral-500)', soft: 'var(--tv-pink-50)' },
  { titulo: 'Camioneta propia', texto: 'Fletes seguros y puntuales', icono: 'camion', color: 'var(--tv-blue-500)', soft: 'var(--tv-blue-50)' },
  { titulo: 'Servicio garantizado', texto: 'Si algo no queda bien, lo arreglo', icono: 'shield', color: 'var(--tv-green-500)', soft: 'var(--tv-mint-100)' },
  { titulo: 'Precio justo', texto: 'Cotizaciones claras y sin letras chicas', icono: 'moneda', color: 'var(--tv-purple-500)', soft: 'var(--tv-lilac-100)' },
  { titulo: 'Respuesta rápida', texto: 'Te respondo por WhatsApp', icono: 'bolt', color: 'var(--tv-orange-500)', soft: '#ffe6d2' },
];

const acentosTestimonio = ['var(--tv-coral-500)', 'var(--tv-green-500)', 'var(--tv-purple-500)'];
---

<AppShell
  title="Opiniones — Tu Vecino Confiable | Jorge Letelier"
  description="Conoce a Jorge Letelier y los trabajos realizados: retiros de cachureos, repisas a medida y fletes. Opiniones reales de vecinos de la V Región."
  active="opiniones"
>
  <!-- Hero humano/editorial (Biblia visual 03.jpeg) -->
  <OpinionsHeroPoster photo={heroJorge} alt="Jorge Letelier junto a su camioneta roja cargada" />

  <!-- 5 mini beneficios -->
  <section class="benefits tv-texture-dots">
    <div class="benefits__row" role="list">
      {
        confianza.map((c) => (
          <div role="listitem" class="benefits__item">
            <BenefitMiniCard icon={c.icono} title={c.titulo} text={c.texto} color={c.color} soft={c.soft} iconSize={34} card />
          </div>
        ))
      }
    </div>
  </section>

  <!-- Trabajos realizados premium -->
  <section class="works">
    <div class="works__head">
      <h2 class="tv-display works__title">Opiniones y trabajos realizados</h2>
      <HandDrawnArrow class="works__arrow" color="var(--tv-orange-500)" width={38} />
    </div>
    <div class="works__list">
      {
        trabajos.map((t) => (
          <WorkCaseCard
            titulo={t.titulo}
            texto={t.texto}
            comuna={t.comuna}
            cat={t.id}
            icono={t.icono}
            foto={fotos[t.imagen].src}
            fotoAlt={fotos[t.imagen].alt}
            antesDespues={t.antesDespues}
          />
        ))
      }
    </div>
  </section>

  <!-- Testimonios premium -->
  <section class="testimonials">
    <div class="testimonials__head">
      <h2 class="tv-display testimonials__title">Lo que dicen mis vecinos</h2>
      <TestimonialScorePill />
    </div>
    <div class="testimonials__list">
      {
        testimonios.map((t, i) => (
          <TestimonialCardPremium
            texto={t.texto}
            nombre={t.nombre}
            comuna={t.comuna}
            estrellas={t.estrellas}
            acento={acentosTestimonio[i % acentosTestimonio.length]}
          />
        ))
      }
    </div>
  </section>
</AppShell>

<style>
  /* ---------- Beneficios (5-up compacto, como 03.jpeg) ---------- */
  .benefits {
    padding: 10px 14px 14px;
    background: var(--tv-cream-50);
  }

  .benefits__row {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 6px;
  }

  /* ---------- Trabajos ---------- */
  .works {
    position: relative;
    padding: 13px 14px 18px;
    background:
      radial-gradient(90% 50% at 92% 4%, rgba(255, 255, 255, 0.6), transparent 30%),
      #ffe9d8;
  }

  .works__head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 9px;
  }

  .works__title {
    font-size: clamp(1.45rem, 6vw, 2.1rem);
    max-width: 16ch;
  }

  .works__arrow { flex: none; }

  .works__list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 7px;
    align-items: start;
  }

  /* ---------- Testimonios ---------- */
  .testimonials {
    padding: 13px 14px 18px;
    background:
      radial-gradient(90% 50% at 8% 4%, rgba(255, 255, 255, 0.55), transparent 28%),
      var(--tv-lilac-50);
  }

  .testimonials__head {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 9px;
  }

  .testimonials__title {
    font-size: clamp(1.4rem, 6vw, 2rem);
    max-width: 9ch;
  }

  .testimonials__list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 7px;
    align-items: start;
  }
</style>
