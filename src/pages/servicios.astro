---
import AppShell from '../layouts/AppShell.astro';
import ServicesHeroBoard from '../components/premium/ServicesHeroBoard.astro';
import PremiumServiceCard from '../components/premium/PremiumServiceCard.astro';
import servicios from '../data/servicios.json';
import { serviceImages } from '../scripts/serviceImages.js';
import jorgeAvatar from '../assets/img/jorge-avatar.png';
import { WA_DISPLAY } from '../scripts/whatsapp.js';

// Parten todos sin marcar; el cliente elige lo que necesita.
const preseleccionados: string[] = [];
---

<AppShell
  title="Servicios — Tu Vecino Confiable | Fletes, traslados y más"
  description="Elige lo que necesitas resolver: fletes pequeños, traslados al aeropuerto, retiro de cachureos, armado de muebles y más. Cotiza por WhatsApp."
  active="servicios"
>
  <!-- Cabecera editorial + card de Jorge (Biblia visual 02.jpeg) -->
  <ServicesHeroBoard jorgePhoto={jorgeAvatar} />

  <!-- Grilla premium de los 9 servicios -->
  <section class="serv-grid-wrap">
    <div class="serv-grid">
      {servicios.map((s) => <PremiumServiceCard servicio={s} selected={preseleccionados.includes(s.id)} photo={serviceImages[s.id as keyof typeof serviceImages]} />)}
    </div>
  </section>

  <!-- Formulario premium sobre menta -->
  <section class="form-wrap tv-texture-grain" id="formulario">
    <div class="form-head">
      <h2 class="tv-display form-titulo">Cuéntame qué necesitas resolver</h2>
      <p class="form-sub">Unos datos rápidos y te preparo la mejor solución.</p>
    </div>

    <form class="form" id="cotiza-form" autocomplete="on">
      <label class="campo">
        <span class="campo-label">Comuna / sector</span>
        <input type="text" id="f-comuna" name="comuna" placeholder="Ej: Santiago Centro, Barrio Yungay" />
      </label>
      <div class="campo-fila">
        <label class="campo">
          <span class="campo-label">Fecha</span>
          <input type="date" id="f-fecha" name="fecha" />
        </label>
        <label class="campo">
          <span class="campo-label">Hora</span>
          <input type="time" id="f-hora" name="hora" />
        </label>
      </div>
      <div class="campo-fila campo-fila--desc">
        <label class="campo">
          <span class="campo-label">Descripción breve</span>
          <textarea
            id="f-detalle"
            name="detalle"
            rows="3"
            placeholder="Ej: Retiro de un refrigerador y un sofá desde mi casa"></textarea>
        </label>

        <div class="campo">
          <span class="campo-label">Sube una foto (opcional)</span>
          <label class="fotozona" for="f-fotos">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 8h2.5L9 5h6l2.5 3H20a1.5 1.5 0 0 1 1.5 1.5V19a1.5 1.5 0 0 1-1.5 1.5H4A1.5 1.5 0 0 1 2.5 19V9.5A1.5 1.5 0 0 1 4 8z" />
            <circle cx="12" cy="13.5" r="3.6" />
            </svg>
            <span>Toca para agregar fotos<br /><small>JPG o PNG hasta 10 MB</small></span>
          </label>
          <input class="sr-only" type="file" id="f-fotos" accept="image/*" multiple />
          <div class="foto-thumbs" id="foto-thumbs"></div>
        </div>
      </div>
      <p class="foto-nota">Las fotos se adjuntan directo en el chat de WhatsApp al enviar el mensaje.</p>
    </form>
  </section>

  <!-- Preview WhatsApp sobre lila + post-it -->
  <section class="preview-wrap">
    <h2 class="tv-display preview-titulo">Mensaje que se enviará por WhatsApp</h2>
    <div class="preview-body">
      <div class="preview-card">
        <div class="preview-head">
          <span class="preview-wa-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z">
              </path>
            </svg>
          </span>
          <span class="preview-num">
            <strong>WhatsApp</strong>
            <small>{WA_DISPLAY}</small>
          </span>
          <button type="button" class="preview-edit" id="btn-editar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16.5 3.7a2.1 2.1 0 0 1 3 3L8 18.2l-4 1 1-4L16.5 3.7z" />
            </svg>
            <span id="btn-editar-label">Editar mensaje</span>
          </button>
        </div>
        <textarea class="preview-text" id="preview-text" rows="4" readonly aria-label="Mensaje para WhatsApp"></textarea>
        <p class="preview-nota" id="preview-nota" hidden>
          Mensaje personalizado: ya no se actualiza solo con el formulario.
        </p>
      </div>

      <aside class="preview-postit" aria-hidden="true">
        <strong>Rápido</strong>
        <span>y sin compromiso</span>
      </aside>
    </div>
  </section>
</AppShell>

<script>
  import { buildWhatsAppMessage, WA_NUMBER } from '../scripts/whatsapp.js';

  const cards = Array.from(document.querySelectorAll('.scard'));
  const inputComuna = document.getElementById('f-comuna') as HTMLInputElement;
  const inputFecha = document.getElementById('f-fecha') as HTMLInputElement;
  const inputHora = document.getElementById('f-hora') as HTMLInputElement;
  const inputDetalle = document.getElementById('f-detalle') as HTMLTextAreaElement;
  const inputFotos = document.getElementById('f-fotos') as HTMLInputElement;
  const thumbs = document.getElementById('foto-thumbs')!;
  const preview = document.getElementById('preview-text') as HTMLTextAreaElement;
  const previewNota = document.getElementById('preview-nota')!;
  const btnEditar = document.getElementById('btn-editar')!;
  const cta = document.getElementById('cta-wa') as HTMLAnchorElement;

  let mensajeManual = false;

  function fechaLegible(valor: string): string {
    if (!valor) return '';
    const [a, m, d] = valor.split('-').map(Number);
    const fecha = new Date(a, m - 1, d);
    return new Intl.DateTimeFormat('es-CL', { weekday: 'long', day: 'numeric', month: 'long' }).format(fecha);
  }

  function serviciosSeleccionados(): string[] {
    return cards
      .filter((c) => c.classList.contains('is-selected'))
      .map((c) => (c as HTMLElement).dataset.serviceName || '');
  }

  function actualizar() {
    if (!mensajeManual) {
      preview.value = buildWhatsAppMessage({
        servicios: serviciosSeleccionados(),
        comuna: inputComuna.value.trim(),
        fecha: fechaLegible(inputFecha.value),
        hora: inputHora.value,
        detalle: inputDetalle.value.trim(),
      });
    }
    cta.href = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(preview.value)}`;
  }

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      card.classList.toggle('is-selected');
      card.setAttribute('aria-pressed', String(card.classList.contains('is-selected')));
      actualizar();
    });
  });

  [inputComuna, inputFecha, inputHora, inputDetalle].forEach((el) => {
    el.addEventListener('input', actualizar);
  });

  const btnEditarLabel = document.getElementById('btn-editar-label')!;

  btnEditar.addEventListener('click', () => {
    if (preview.readOnly) {
      preview.readOnly = false;
      preview.focus();
      mensajeManual = true;
      previewNota.hidden = false;
      btnEditarLabel.textContent = 'Listo';
    } else {
      preview.readOnly = true;
      btnEditarLabel.textContent = 'Editar mensaje';
      actualizar();
    }
  });

  preview.addEventListener('input', actualizar);

  // Miniaturas de fotos, solo en el navegador (se adjuntan a mano en WhatsApp)
  inputFotos.addEventListener('change', () => {
    thumbs.innerHTML = '';
    Array.from(inputFotos.files || []).forEach((file, i) => {
      const url = URL.createObjectURL(file);
      const cont = document.createElement('span');
      cont.className = 'foto-thumb';
      const img = document.createElement('img');
      img.src = url;
      img.alt = `Foto ${i + 1}`;
      const x = document.createElement('button');
      x.type = 'button';
      x.className = 'foto-x';
      x.setAttribute('aria-label', 'Quitar foto');
      x.textContent = '×';
      x.addEventListener('click', () => {
        URL.revokeObjectURL(url);
        cont.remove();
      });
      cont.append(img, x);
      thumbs.append(cont);
    });
  });

  actualizar();
</script>

<style>
  /* ---------- Grilla ---------- */
  .serv-grid-wrap {
    padding: 10px 14px;
    background: var(--tv-cream-50);
  }

  .serv-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 6px;
  }

  /* ---------- Formulario ---------- */
  .form-wrap {
    margin: 0 14px;
    padding: 12px 14px 14px;
    border-radius: var(--tv-radius-panel);
    background:
      radial-gradient(90% 50% at 90% 4%, rgba(255, 255, 255, 0.6), transparent 30%),
      var(--tv-mint-50);
    box-shadow: var(--tv-shadow-soft);
  }

  .form-head { margin-bottom: 6px; }

  .form-titulo {
    font-size: clamp(1.4rem, 5.6vw, 2rem);
    line-height: 0.98;
  }

  .form-sub {
    margin: 4px 0 0;
    font-size: 12.5px;
    font-weight: 700;
    color: var(--tv-ink-soft);
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .campo {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .campo-label {
    font-size: 12.5px;
    font-weight: 900;
    color: var(--tv-ink);
  }

  .campo input,
  .campo textarea {
    background: rgba(255, 255, 255, 0.96);
    border: 1.5px solid rgba(10, 25, 50, 0.1);
    border-radius: 13px;
    padding: 9px 12px;
    font-size: 16px;
    font-weight: 600;
    color: var(--tv-ink);
    min-height: 42px;
    width: 100%;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .campo textarea {
    resize: vertical;
    min-height: 66px;
  }

  .campo input:focus-visible,
  .campo textarea:focus-visible {
    outline: 2.5px solid var(--tv-green-500);
    outline-offset: 1px;
    border-color: transparent;
  }

  .campo-fila {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 11px;
  }

  .campo-fila .campo { min-width: 0; }
  .campo-fila input { min-width: 0; }

  /* Descripción (izq) + Sube foto (der) lado a lado, como 02.jpeg */
  .campo-fila--desc {
    grid-template-columns: 1.15fr 0.85fr;
    align-items: stretch;
  }

  .campo-fila--desc .campo { height: 100%; }
  .campo-fila--desc textarea {
    flex: 1;
    min-height: 66px;
  }
  .campo-fila--desc .fotozona {
    flex: 1;
    min-height: 66px;
  }

  .fotozona {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    border: 2px dashed rgba(24, 176, 122, 0.45);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.7);
    padding: 11px 12px;
    color: var(--tv-ink-soft);
    font-size: 12.5px;
    font-weight: 800;
    text-align: center;
    line-height: 1.3;
    cursor: pointer;
    min-height: 52px;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .fotozona:hover { border-color: var(--tv-green-500); background: rgba(255, 255, 255, 0.9); }

  .fotozona svg {
    width: 27px;
    height: 27px;
    color: var(--tv-green-500);
  }

  .fotozona small {
    font-weight: 600;
    opacity: 0.75;
  }

  .foto-thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }

  .foto-thumbs:empty { display: none; }

  .foto-thumbs :global(.foto-thumb) {
    position: relative;
    width: 62px;
    height: 62px;
  }

  .foto-thumbs :global(.foto-thumb img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    border: 2px solid #fff;
    box-shadow: var(--tv-shadow-card);
  }

  .foto-thumbs :global(.foto-x) {
    position: absolute;
    top: -7px;
    right: -7px;
    width: 21px;
    height: 21px;
    border-radius: 50%;
    background: var(--tv-navy-900);
    color: #fff;
    font-size: 14px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .foto-nota {
    font-size: 11px;
    font-weight: 600;
    color: var(--tv-ink-soft);
    opacity: 0.85;
  }

  /* ---------- Preview WhatsApp ---------- */
  .preview-wrap {
    padding: 12px 14px 16px;
    background:
      radial-gradient(90% 50% at 10% 4%, rgba(255, 255, 255, 0.55), transparent 28%),
      var(--tv-lilac-50);
  }

  .preview-titulo {
    font-size: clamp(1.2rem, 4.6vw, 1.6rem);
    margin-bottom: 8px;
  }

  .preview-body {
    display: grid;
    gap: 10px;
  }

  .preview-card {
    background: rgba(255, 255, 255, 0.96);
    border-radius: 20px;
    padding: 11px;
    box-shadow: var(--tv-shadow-card);
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .preview-head {
    display: flex;
    align-items: center;
    gap: 9px;
  }

  .preview-wa-icon {
    width: 38px;
    height: 38px;
    min-width: 38px;
    border-radius: 50%;
    background: #25d366;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .preview-wa-icon svg { width: 21px; height: 21px; }

  .preview-num {
    flex: 1;
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .preview-num strong {
    font-size: 13.5px;
    font-weight: 900;
    color: var(--tv-ink);
  }

  .preview-num small {
    font-size: 12px;
    font-weight: 700;
    color: var(--tv-ink-soft);
  }

  .preview-edit {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    font-weight: 900;
    color: var(--tv-purple-500);
    background: var(--tv-lilac-100);
    border-radius: 999px;
    padding: 9px 13px;
    min-height: 38px;
  }

  .preview-edit:focus-visible {
    outline: 2.5px solid var(--tv-purple-500);
    outline-offset: 2px;
  }

  .preview-edit svg { width: 13px; height: 13px; }

  .preview-text {
    border: 1.5px dashed var(--tv-lilac-100);
    background: #faf7ff;
    border-radius: 16px;
    padding: 13px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--tv-ink);
    line-height: 1.5;
    width: 100%;
    resize: vertical;
  }

  .preview-text:not([readonly]) {
    border-style: solid;
    border-color: var(--tv-purple-500);
    outline: none;
  }

  .preview-nota {
    font-size: 11px;
    font-weight: 800;
    color: var(--tv-purple-600);
  }

  /* post-it "Rápido y sin compromiso" */
  .preview-postit {
    justify-self: end;
    display: grid;
    place-items: center;
    text-align: center;
    width: 132px;
    padding: 14px 12px;
    border-radius: 6px 16px 16px 16px;
    background: linear-gradient(160deg, #fff2b8, #ffe27a);
    color: var(--tv-ink);
    box-shadow: 0 10px 22px rgba(229, 169, 0, 0.28);
    transform: rotate(3deg);
    line-height: 1.1;
  }

  .preview-postit strong {
    font-family: var(--font-hand);
    font-size: 1.7rem;
    font-weight: 700;
  }

  .preview-postit span {
    font-size: 0.78rem;
    font-weight: 800;
  }
</style>
