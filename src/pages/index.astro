---
import AppShell from '../layouts/AppShell.astro';
import HeroPoster from '../components/premium/HeroPoster.astro';
import FeatureInfoCard from '../components/premium/FeatureInfoCard.astro';
import ServiceRowPremium from '../components/premium/ServiceRowPremium.astro';
import HandwrittenText from '../components/premium/HandwrittenText.astro';
import HandDrawnArrow from '../components/premium/HandDrawnArrow.astro';
import servicios from '../data/servicios.json';
import heroFoto from '../assets/img/hero-camioneta.png';

const destacados = servicios.filter((s) => s.destacado);
---

<AppShell
  title="Tu Vecino Confiable — Fletes y traslados en Santiago y la V Región"
  description="Jorge Letelier te ayuda con fletes pequeños, traslados al aeropuerto, retiro de cachureos y soluciones prácticas para la casa. Cotiza rápido por WhatsApp."
  active="inicio"
>
  <!-- Hero póster editorial (Biblia visual 01.jpeg) -->
  <HeroPoster photo={heroFoto} alt="Jorge sobre su camioneta roja cargada con muebles" />

  <!-- Cards de cobertura / viajes -->
  <section class="cobertura">
    <FeatureInfoCard
      icon="pin"
      title="Atención en Santiago"
      text="y alrededores"
      href="/servicios"
    />
    <FeatureInfoCard
      icon="beach"
      title="Viajes especiales a Viña / Valparaíso"
      text="previa cotización"
      href="/servicios#vina"
      iconBg="var(--tv-blue-50)"
      iconFg="var(--tv-navy-900)"
      arrowBg="#fde9c2"
      arrowFg="var(--tv-yellow-600)"
    />
  </section>

  <!-- Servicios destacados como lista editorial sobre menta -->
  <section class="destacados tv-texture-dots">
    <svg class="destacados__sprouts" viewBox="0 0 320 60" fill="none" aria-hidden="true">
      <g stroke="var(--tv-green-500)" stroke-width="2" stroke-linecap="round">
        <path d="M22 50 V36" /><path d="M22 40 C16 38 13 34 14 30 C20 30 22 35 22 40Z" fill="var(--tv-green-500)" opacity="0.5" /><path d="M22 37 C28 35 31 31 30 27 C24 27 22 32 22 37Z" fill="var(--tv-green-500)" opacity="0.5" />
        <path d="M300 16 V4" /><path d="M300 9 C295 7 292 4 293 1 C298 1 300 5 300 9Z" fill="var(--tv-green-500)" opacity="0.45" />
        <path d="M170 54 q4 -6 8 0" opacity="0.4" />
      </g>
    </svg>
    <div class="destacados__intro">
      <div class="destacados__heading">
        <HandwrittenText class="destacados__eyebrow" size="1.5rem" rotate="-3deg">Lo más pedido</HandwrittenText>
        <h2 class="tv-display destacados__title">Servicios destacados</h2>
      </div>
      <HandDrawnArrow class="destacados__arrow" color="var(--tv-coral-500)" width={36} />
      <a class="tv-pill-coral destacados__all" href="/servicios">Ver todos los servicios →</a>
    </div>

    <div class="destacados__panel">
      {destacados.map((s) => <ServiceRowPremium servicio={s} />)}
    </div>
  </section>
</AppShell>

<style>
  .cobertura {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    padding: 0 var(--page-x) 8px;
    background: var(--tv-cream-50);
  }

  .destacados {
    position: relative;
    padding: 8px var(--page-x) 12px;
    background:
      radial-gradient(90% 60% at 8% 4%, rgba(255, 255, 255, 0.7), transparent 26%),
      var(--tv-mint-50);
  }

  .destacados__sprouts {
    position: absolute;
    top: 8px;
    left: 0;
    width: 100%;
    height: 56px;
    z-index: 0;
    pointer-events: none;
    opacity: 0.7;
  }

  .destacados__intro {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 4px 10px;
    margin-bottom: 8px;
  }

  .destacados__heading { grid-column: 1; grid-row: 1; }

  .destacados__eyebrow {
    margin-bottom: 1px;
    color: var(--tv-ink);
  }

  .destacados__title {
    font-size: clamp(1.6rem, 7vw, 2.3rem);
    line-height: 0.95;
  }

  /* flecha doodle pequeña, encima de la pill */
  .destacados__arrow {
    position: absolute;
    top: -6px;
    right: 8px;
    width: 38px;
  }

  .destacados__all {
    grid-column: 2;
    grid-row: 1;
    justify-self: end;
    align-self: center;
    padding: 0.55rem 0.85rem;
    font-size: 0.82rem;
  }

  .destacados__panel {
    border-radius: var(--tv-radius-panel);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: var(--tv-shadow-soft);
    padding: 2px 12px;
  }
</style>
